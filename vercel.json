{
  "version": 2,
  "builds": [
    {
      "src": "frontend/package.json",
      "use": "@vercel/static-build",
      "config": { 
        "distDir": "build",
        "installCommand": "npm ci"
      }
    },
    {
      "src": "frontend/api/health.py",
      "use": "@vercel/python"
    },
    {
      "src": "frontend/api/generate.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/api/health",
      "dest": "frontend/api/health.py"
    },
    {
      "src": "/api/generate",
      "dest": "frontend/api/generate.py"
    },
    {
      "src": "/static/(.*)",
      "dest": "frontend/build/static/$1"
    },
    {
      "src": "/(.*)",
      "dest": "frontend/build/index.html"
    }
  ],
  "outputDirectory": "frontend/build"
}